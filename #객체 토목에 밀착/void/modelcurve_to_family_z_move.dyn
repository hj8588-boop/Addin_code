      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "from pathlib import Path\n\nscript_name = \"move_family_to_modelcurve_z.py\"\nroot_path = Path(r\"C:\\Users\\user\\Desktop\\codex\")\ncandidate_paths = [\n    root_path / \"#workplane_family_to_nearest_wall\" / script_name,\n    root_path / script_name,\n]\n\nscript_path = None\nfor candidate in candidate_paths:\n    if candidate.exists():\n        script_path = candidate\n        break\n\nif script_path is None:\n    matches = list(root_path.rglob(script_name))\n    if matches:\n        script_path = matches[0]\n\nif script_path is None:\n    raise FileNotFoundError(\"Could not find {0} under {1}\".format(script_name, root_path))\n\nnamespace = {\"IN\": IN}\nwith open(str(script_path), \"r\", encoding=\"utf-8\") as handle:\n    code = handle.read()\nexec(compile(code, str(script_path), \"exec\"), namespace)\nOUT = namespace.get(\"OUT\")\n",
